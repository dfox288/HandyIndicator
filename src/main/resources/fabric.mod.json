{
    "schemaVersion": 1,
    "id": "handyindicator",
    "version": "${version}",
    "name": "Handy Indicator",
    "description": "Shows a subtle visual indicator on container blocks (chests, trapped chests, copper chests, hoppers, dispensers, droppers, barrels, crafters, furnaces, decorated pots, shulker boxes) when they contain items. Fully configurable with per-block toggles and custom indicator colors via YACL.",
    "authors": ["D.Fox"],
    "contact": {
        "homepage": "https://github.com/dfox288/HandyIndicator",
        "sources": "https://github.com/dfox288/HandyIndicator",
        "issues": "https://github.com/dfox288/HandyIndicator/issues"
    },
    "icon": "assets/handyindicator/icon.png",
    "license": "MIT",
    "environment": "*",
    "entrypoints": {
        "main": [
            "dev.handy.mods.handyindicator.HandyIndicator"
        ],
        "client": [
            "dev.handy.mods.handyindicator.HandyIndicatorClient"
        ],
        "modmenu": [
            "dev.handy.mods.handyindicator.HandyIndicatorModMenu"
        ]
    },
    "mixins": [
        "handyindicator.mixins.json",
        {
            "config": "handyindicator-client.mixins.json",
            "environment": "client"
        }
    ],
    "depends": {
        "fabricloader": ">=0.19.2",
        "minecraft": ">=26.2-alpha.1",
        "java": ">=25",
        "fabric-api": "*"
    },
    "suggests": {
        "modmenu": "*",
        "yet_another_config_lib_v3": "*"
    }
}
